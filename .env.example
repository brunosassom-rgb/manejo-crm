# Copie para .env e preencha (Supabase -> Project Settings -> API).
# SUPABASE_SERVICE_ROLE_KEY ignora RLS por completo -- é só para o script de
# migração local, roda uma única vez, e NUNCA deve ir para o app.js (que usa
# a anon key) nem ser commitado no git.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
